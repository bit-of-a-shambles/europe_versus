<% content_for(:title) { "Fact Checks — EUROPEVERSUS" } %>

<div class="max-w-7xl mx-auto px-4 md:px-6">
  <!-- Hero Section -->
  <section class="bg-[#111] text-white -mx-4 md:-mx-6 px-4 md:px-6 border-b-[6px] border-[#0066FF]">
    <div class="max-w-7xl mx-auto py-12 md:py-16">
      <span class="font-mono text-[10px] uppercase tracking-[0.14em] bg-[#0066FF] text-white px-3 py-1 inline-block mb-4">
        Fact Check Dashboard
      </span>
      <h1 class="text-4xl md:text-6xl lg:text-8xl font-black tracking-tighter mb-4">
        Myths busted.<br>
        <span class="text-[#0066FF]">Receipts ready.</span>
      </h1>
      <p class="text-base md:text-lg text-white/55 max-w-2xl">
        Data-backed responses to the most common myths about Europe. Every claim is checked, every number is sourced.
      </p>
    </div>
  </section>

  <!-- Articles Grid -->
  <% if @fact_checks.any? %>
    <section class="py-12 md:py-16">
      <div class="grid md:grid-cols-2 gap-5">
        <% @fact_checks.each do |fact_check| %>
          <%
            vc = fact_check.verdict_config
            qs = fact_check.quick_stats.first
          %>
          <div class="border-2 border-black bg-white flex flex-col hover:-translate-y-0.5 hover:shadow-[6px_6px_0_0_#000] transition-all">
            <!-- Card head: topic + verdict badge -->
            <div class="p-5 pb-3 flex items-start justify-between gap-3">
              <div class="flex flex-wrap items-center gap-2">
                <% if fact_check.created_at %>
                  <span class="font-mono text-[10px] text-black/40"><%= fact_check.created_at.strftime("%B %Y") %></span>
                <% end %>
                <span class="font-mono text-[10px] bg-black text-white px-2 py-0.5"><%= fact_check.metrics.size %> metrics</span>
              </div>
              <% if fact_check.verdict_rating.present? %>
                <span class="shrink-0 font-mono text-[9px] font-bold uppercase tracking-[0.06em] px-2.5 py-1 text-white"
                      style="background-color: <%= vc[:color] %>;">
                  <%= vc[:label] %>
                </span>
              <% end %>
            </div>

            <!-- Claim -->
            <div class="px-5 mb-3">
              <%= link_to fact_check_path(slug: fact_check.slug), class: "block group" do %>
                <h2 class="text-xl md:text-2xl font-black tracking-tight leading-snug group-hover:text-[#0066FF] transition-colors">
                  <% if fact_check.claim.present? %>
                    "<%= fact_check.claim %>"
                  <% else %>
                    <%= fact_check.title %>
                  <% end %>
                </h2>
              <% end %>
            </div>

            <!-- Key stat (if quick_stats exist) -->
            <% if qs %>
              <div class="px-5 mb-4">
                <p class="font-mono text-[9px] uppercase tracking-[0.1em] text-black/40 mb-1">Key data point</p>
                <div class="flex items-baseline gap-2">
                  <span class="text-2xl font-black text-[#0066FF]"><%= qs["value"] %></span>
                  <span class="font-mono text-xs text-black/40"><%= qs["label"] %></span>
                </div>
              </div>
            <% end %>

            <!-- Quick tweet snippet -->
            <% if fact_check.tweets.any? %>
              <div class="mx-5 mb-4 p-3 bg-[#F5F5F5] border-t-2 border-black/5 text-sm text-black/65 leading-snug">
                <strong class="text-black">Quick reply:</strong> <%= truncate(fact_check.tweets.first, length: 150) %>
              </div>
            <% end %>

            <div class="mt-auto"></div>

            <!-- Footer -->
            <div class="border-t-2 border-black p-3 px-5 flex items-center justify-between gap-2">
              <%= link_to fact_check_path(slug: fact_check.slug),
                  class: "font-mono text-[10px] uppercase tracking-brutal font-bold px-3 py-2 bg-[#0066FF] text-white hover:bg-[#0055DD] transition-colors" do %>
                Read More →
              <% end %>
              <% if fact_check.tweets.any? %>
                <button onclick="navigator.clipboard.writeText('<%= j(fact_check.tweets.first) %>');this.textContent='Copied!';setTimeout(()=>{this.textContent='Copy Stat'},2000)"
                        class="font-mono text-[9px] uppercase tracking-brutal font-bold px-3 py-2 border border-black/20 hover:bg-black hover:text-white hover:border-black transition-colors">
                  Copy Stat
                </button>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </section>
  <% else %>
    <section class="py-16 md:py-24">
      <div class="text-center">
        <div class="font-mono text-6xl mb-6">📊</div>
        <h2 class="text-2xl font-bold mb-4">Coming Soon</h2>
        <p class="text-black/60 max-w-md mx-auto">
          We're working on in-depth fact-check articles. Check back soon for evidence-based analysis of common claims about Europe.
        </p>
        <%= link_to statistics_path, class: "inline-block mt-6 font-mono text-sm uppercase tracking-brutal border-2 border-black px-6 py-3 hover:bg-black hover:text-white transition-colors" do %>
          Browse Statistics →
        <% end %>
      </div>
    </section>
  <% end %>

  <!-- What to Expect Section -->
  <section class="border-t-2 border-black py-12 md:py-16">
    <h2 class="font-mono text-xs uppercase tracking-brutal text-black/60 mb-8">How it works</h2>
    <div class="grid md:grid-cols-3 gap-0">
      <div class="border-2 border-black p-6">
        <span class="font-mono text-4xl font-bold text-black/20">01</span>
        <h3 class="font-mono text-sm uppercase tracking-brutal font-bold mt-4 mb-2">Pick a Myth</h3>
        <p class="text-sm text-black/70">Find the claim you've seen on social media and click through to get the data.</p>
      </div>
      <div class="border-2 border-black border-t-0 md:border-t-2 md:border-l-0 p-6">
        <span class="font-mono text-4xl font-bold text-black/20">02</span>
        <h3 class="font-mono text-sm uppercase tracking-brutal font-bold mt-4 mb-2">Share the Facts</h3>
        <p class="text-sm text-black/70">Key stats, pre-written talking points, and shareable cards — all copy-paste ready.</p>
      </div>
      <div class="border-2 border-black border-t-0 md:border-t-2 md:border-l-0 p-6">
        <span class="font-mono text-4xl font-bold text-black/20">03</span>
        <h3 class="font-mono text-sm uppercase tracking-brutal font-bold mt-4 mb-2">Post the Receipt</h3>
        <p class="text-sm text-black/70">Reply with data. Every claim is checked, every number is sourced.</p>
      </div>
    </div>
  </section>
</div>

<%# Tweet Arsenal - copyable pre-written tweets for Twitter fact-checking %>
<%# Usage: render partial: "fact_checks/tweet_arsenal", locals: { tweets: @fact_check.tweets, fact_check: @fact_check } %>
<% if tweets.any? %>
<div class="my-10 not-prose" data-controller="copy">
  <div class="border-4 border-black bg-white">
    <!-- Header -->
    <div class="border-b-4 border-black p-4 md:p-6">
      <span class="font-mono text-xs uppercase tracking-brutal bg-black text-white px-3 py-1 inline-block mb-2">
        Rapid Response Kit
      </span>
      <h3 class="text-xl md:text-2xl font-black tracking-tight">
        Ready-to-post talking points
      </h3>
      <p class="text-sm text-black/60 mt-1">Data-backed, source-cited, ≤280 characters. Post directly or download as an image.</p>
    </div>

    <!-- Tweets -->
    <div class="divide-y-2 divide-black/10">
      <% tweets.each_with_index do |tweet, idx| %>
        <div class="p-4 md:p-6 hover:bg-[#F5F5F5] transition-colors group">
          <div class="flex items-start gap-4">
            <!-- Number -->
            <span class="shrink-0 w-8 h-8 flex items-center justify-center bg-[#0066FF] text-white font-mono text-xs font-bold">
              <%= idx + 1 %>
            </span>
            
            <!-- Tweet content -->
            <div class="flex-1 min-w-0">
              <p class="text-sm md:text-base leading-relaxed text-black/85" id="tweet-<%= idx %>">
                <%= tweet %>
              </p>
              <div class="flex items-center justify-between mt-3">
                <span class="font-mono text-[10px] text-black/30">
                  <%= tweet.length %>/280
                </span>
                <div class="flex items-center gap-2">
                  <button onclick="downloadTweetCard(<%= idx %>)"
                          class="inline-flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-brutal font-bold px-3 py-1.5 border border-[#0066FF] text-[#0066FF] hover:bg-[#0066FF] hover:text-white transition-colors"
                          title="Download as shareable image">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                    Image
                  </button>
                  <a href="https://twitter.com/intent/tweet?text=<%= CGI.escape(tweet) %>&url=<%= CGI.escape(fact_check_url(slug: fact_check.slug)) %>"
                     target="_blank"
                     rel="noopener noreferrer"
                     class="inline-flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-brutal font-bold px-3 py-1.5 bg-black text-white hover:bg-[#0066FF] transition-colors">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    Post
                  </a>
                  <button onclick="copyTweet(<%= idx %>)"
                          class="font-mono text-[10px] uppercase tracking-brutal font-bold px-3 py-1.5 border border-black/20 hover:bg-black hover:text-white hover:border-black transition-colors">
                    Copy
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Footer -->
    <div class="border-t-2 border-black/20 p-3 md:p-4 bg-[#F5F5F5] flex items-center justify-between">
      <span class="font-mono text-xs text-black/50">
        <%= tweets.size %> talking points
      </span>
      <button onclick="copyAllTweets()"
              class="font-mono text-xs uppercase tracking-brutal text-[#0066FF] hover:underline font-bold">
        Copy all →
      </button>
    </div>
  </div>
</div>

<!-- Hidden share cards for image generation (positioned off-screen) -->
<div id="tweet-cards-offscreen" aria-hidden="true" style="position:absolute;left:-9999px;top:0;">
  <% tweets.each_with_index do |tweet, idx| %>
    <div id="tweet-card-<%= idx %>" style="width:1200px;height:675px;background:#fff;display:flex;flex-direction:column;justify-content:space-between;padding:72px 80px;font-family:Inter,system-ui,sans-serif;box-sizing:border-box;border:6px solid #0066FF;">
      <!-- Top: claim struck through -->
      <div>
        <div style="font-family:'Space Mono',monospace;font-size:13px;letter-spacing:0.12em;text-transform:uppercase;color:#0066FF;margin-bottom:24px;">EUROPE<span style="color:#000;">VERSUS</span> · FACT CHECK</div>
        <div style="font-size:22px;color:#999;text-decoration:line-through;line-height:1.3;margin-bottom:32px;"><%= fact_check.claim %></div>
      </div>
      <!-- Middle: tweet text -->
      <div style="font-size:28px;font-weight:700;line-height:1.45;color:#000;flex:1;display:flex;align-items:center;">
        <span><%= tweet %></span>
      </div>
      <!-- Bottom: verdict + branding -->
      <div style="display:flex;justify-content:space-between;align-items:flex-end;">
        <div>
          <% config = FactCheck::RATING_CONFIG[fact_check.verdict_rating] || FactCheck::RATING_CONFIG["mixed"] %>
          <span style="display:inline-block;background:<%= config[:color] %>;color:#fff;font-family:'Space Mono',monospace;font-size:14px;letter-spacing:0.12em;text-transform:uppercase;padding:8px 16px;font-weight:700;">
            <%= config[:icon] %> <%= config[:label] %>
          </span>
        </div>
        <div style="font-family:'Space Mono',monospace;font-size:13px;letter-spacing:0.12em;color:#999;">
          europeversus.eu
        </div>
      </div>
    </div>
  <% end %>
</div>

<script>
  var tweetTexts = <%= raw tweets.to_json %>;

  function copyTweet(idx) {
    navigator.clipboard.writeText(tweetTexts[idx]).then(function() {
      showCopyToast('Tweet copied!');
    });
  }

  function copyAllTweets() {
    var all = tweetTexts.map(function(t, i) { return (i + 1) + '. ' + t; }).join('\n\n');
    navigator.clipboard.writeText(all).then(function() {
      showCopyToast('All tweets copied!');
    });
  }

  function downloadTweetCard(idx) {
    var card = document.getElementById('tweet-card-' + idx);
    if (!card) return;
    // Temporarily make visible for capture
    var container = document.getElementById('tweet-cards-offscreen');
    container.style.left = '0';
    container.style.position = 'fixed';
    container.style.top = '0';
    container.style.zIndex = '-1';
    container.style.opacity = '0';

    import('https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.esm.js').then(function(mod) {
      var html2canvas = mod.default;
      html2canvas(card, { scale: 2, useCORS: true, backgroundColor: '#ffffff' }).then(function(canvas) {
        container.style.left = '-9999px';
        container.style.position = 'absolute';
        container.style.zIndex = '';
        container.style.opacity = '';
        var link = document.createElement('a');
        link.download = 'europeversus-fact-' + (idx + 1) + '.png';
        link.href = canvas.toDataURL('image/png');
        link.click();
        showCopyToast('Image downloaded!');
      }).catch(function() {
        container.style.left = '-9999px';
        container.style.position = 'absolute';
        showCopyToast('Download failed — try again');
      });
    });
  }

  function showCopyToast(msg) {
    var existing = document.getElementById('copy-toast-el');
    if (existing) existing.remove();
    var toast = document.createElement('div');
    toast.id = 'copy-toast-el';
    toast.style.cssText = 'position:fixed;bottom:24px;right:24px;background:#0066FF;color:#fff;padding:12px 20px;font-family:"Space Mono",monospace;font-size:12px;z-index:9999;transition:opacity 0.3s;';
    toast.textContent = msg;
    document.body.appendChild(toast);
    setTimeout(function() { toast.style.opacity = '0'; }, 1800);
    setTimeout(function() { toast.remove(); }, 2200);
  }
</script>
<% end %>

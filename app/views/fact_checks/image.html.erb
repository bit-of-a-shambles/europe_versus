<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=Space+Mono:wght@400;700&display=swap');
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: white;
      width: 1200px;
      height: 630px;
      overflow: hidden;
    }
    
    .font-mono {
      font-family: 'Space Mono', monospace;
    }
    
    .card {
      width: 1200px;
      height: 630px;
      background: #FFFFFF;
      color: #000;
      display: flex;
      flex-direction: column;
      border-bottom: 8px solid #0066FF;
    }
    
    .card-header {
      padding: 48px 56px 24px;
    }
    
    .badge {
      display: inline-block;
      background: #0066FF;
      color: white;
      padding: 8px 16px;
      font-family: 'Space Mono', monospace;
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      margin-bottom: 24px;
    }
    
    .claim {
      font-size: 42px;
      font-weight: 900;
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: rgba(0,0,0,0.3);
      text-decoration: line-through;
      text-decoration-color: #DC2626;
      text-decoration-thickness: 3px;
      max-width: 900px;
    }
    
    .card-body {
      flex: 1;
      padding: 24px 56px;
      display: flex;
      align-items: flex-start;
      gap: 32px;
    }
    
    .verdict-stamp {
      font-family: 'Space Mono', monospace;
      font-size: 16px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 10px 20px;
      border: 3px solid;
      white-space: nowrap;
    }
    
    .summary {
      font-size: 22px;
      color: rgba(0,0,0,0.55);
      line-height: 1.45;
      max-width: 700px;
    }
    
    .card-footer {
      padding: 28px 56px;
      background: #F8F9FA;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 2px solid rgba(0,0,0,0.06);
    }
    
    .stats {
      display: flex;
      gap: 32px;
    }
    
    .stat-label {
      font-family: 'Space Mono', monospace;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(0,0,0,0.35);
      margin-bottom: 2px;
    }
    
    .stat-val {
      font-size: 28px;
      font-weight: 900;
      color: #0066FF;
    }
    
    .brand {
      font-family: 'Space Mono', monospace;
      font-size: 22px;
      font-weight: bold;
      color: rgba(0,0,0,0.25);
    }
    .brand span {
      color: #0066FF;
    }
  </style>
</head>
<body>
  <%
    vc = fact_check.verdict_config
    qs = fact_check.quick_stats
  %>
  <div class="card">
    <div class="card-header">
      <span class="badge">Fact Check</span>
      <% if fact_check.claim.present? %>
        <p class="claim">"<%= fact_check.claim %>"</p>
      <% else %>
        <p class="claim" style="text-decoration:none; color: #000;"><%= fact_check.title %></p>
      <% end %>
    </div>
    
    <div class="card-body">
      <% if fact_check.verdict_rating.present? %>
        <span class="verdict-stamp" style="border-color: <%= vc[:color] %>; color: <%= vc[:color] %>;">
          <%= vc[:icon] %> <%= vc[:label] %>
        </span>
      <% end %>
      <% if fact_check.subtitle.present? %>
        <p class="summary"><%= fact_check.subtitle %></p>
      <% end %>
    </div>
    
    <div class="card-footer">
      <div class="stats">
        <% qs.first(3).each do |stat| %>
          <div>
            <div class="stat-label"><%= stat["label"] %></div>
            <div class="stat-val"><%= stat["value"] %></div>
          </div>
        <% end %>
        <% if qs.empty? %>
          <% fact_check.metrics.first(3).each do |metric| %>
            <span class="font-mono" style="font-size:12px; padding:6px 12px; border:1px solid rgba(0,0,0,0.15); text-transform:uppercase; letter-spacing:0.05em; color:rgba(0,0,0,0.45);">
              <%= metric.tr("_", " ").split.first(2).join(" ") %>
            </span>
          <% end %>
        <% end %>
      </div>
      <span class="brand">EUROPE<span>VERSUS</span></span>
    </div>
  </div>
</body>
</html>
